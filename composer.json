{
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.89",
    "squizlabs/php_codesniffer": "^4.0",
    "phpunit/phpunit": "^11.5",
    "symfony/console": "^6.4 || ^7.0"
  },
  "scripts": {
    "test": "phpunit",
    "sugar:module:install": "php bin/sugar-module-install.php install",
    "sugar:module:uninstall": "php bin/sugar-module-install.php uninstall",
    "sugar:repair": "php bin/sugar-module-install.php repair"
  },
  "autoload": {
    "psr-4": {
      "SugarAdminCLI\\Dev\\": "src/Dev/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SugarAdminCLI\\Tests\\": "tests/",
      "Sugarcrm\\Sugarcrm\\custom\\amaiza\\SugarAdminCLI\\Console\\Command\\": "crm/custom/src/amaiza/SugarAdminCLI/Console/Command/"
    }
  }
}
