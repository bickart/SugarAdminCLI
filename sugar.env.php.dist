<?php

/**
 * Local Sugar instance configuration for development linking.
 *
 * Copy to sugar.env.php (gitignored) and set sugar_root to your Sugar web root.
 *
 * Example:
 *   cp sugar.env.php.dist sugar.env.php
 *   composer sugar:module:install
 *   composer sugar:repair
 */
return [
    // Absolute path to your Sugar instance root (the directory containing index.php).
    'sugar_root' => '/path/to/your/sugar/install',

    // Command used for Quick Repair and Rebuild (must accept the Sugar root path as its argument).
    'sugar_repair_command' => 'sugar_repair',

    // false is the safer default (works with Docker-mounted or otherwise
    // isolated Sugar instances). Set true for a plain symlink instead of a copy.
    'use_symlinks' => false,
];
